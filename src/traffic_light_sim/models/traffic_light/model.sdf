      <visual name="head1_red_visual_on"><pose>0.0305 0 0.335 0 0 0</pose><geometry><sphere><radius>0.0122</radius></sphere></geometry><material><ambient>1 0.2 0.2 1</ambient><diffuse>1 0 0 1</diffuse><emissive>1 0 0 1</emissive></material></visual>

