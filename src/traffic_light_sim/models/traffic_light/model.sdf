<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="traffic_light">
    <static>true</static>
    
    <link name="base_link">
      
      <visual name="pole_visual">
        <pose>0 0 0.3 0 0 0</pose> <geometry><cylinder><radius>0.01</radius><length>0.6</length></cylinder></geometry> <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>

      <visual name="arm_visual">
        <pose>0 -0.25 0.55 1.5707 0 0</pose> <geometry><cylinder><radius>0.008</radius><length>0.5</length></cylinder></geometry> <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>


      <visual name="head1_body">
        <pose>0.015 0 0.3 0 0 0</pose> <geometry><box><size>0.03 0.03 0.11</size></box></geometry> <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>

      <visual name="head1_visor_red"><pose>0.032 0 0.348 0 0.15 0</pose><geometry><box><size>0.015 0.026 0.002</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
